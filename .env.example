# Copy this file to .env and fill in your Firebase service account credentials.
# Get these values from Firebase Console → Project Settings → Service Accounts → Generate new private key.

FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Optional: change port (default 4000)
# PORT=4000
